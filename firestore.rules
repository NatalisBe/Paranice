rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isGameHost(gameId) {
      return get(/databases/$(database)/documents/games/$(gameId)).data.hostId == request.resource.data.hostId ||
             get(/databases/$(database)/documents/games/$(gameId)).data.hostId == resource.data.hostId;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /games/{gameId} {
      allow read, write: if true;
      
      match /players/{playerId} {
        allow read, write: if true;
      }
      
      match /teams/{teamId} {
        allow read, write: if true;
      }
      
      match /figures/{figureId} {
        allow read, write: if true;
      }
    }
  }
}
