{
  "entities": {
    "Game": {
      "title": "Game",
      "description": "A game session",
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["waiting", "countdown", "playing", "finished"]
        },
        "hostId": {
          "type": "string"
        },
        "startedAt": {
          "type": "number"
        },
        "duration": {
          "type": "number"
        }
      },
      "required": ["status", "hostId", "duration"]
    },
    "Player": {
      "title": "Player",
      "description": "A player in a game",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "characterId": {
          "type": "string"
        },
        "score": {
          "type": "number"
        },
        "joinedAt": {
          "type": "number"
        }
      },
      "required": ["name", "score", "joinedAt"]
    },
    "Figure": {
      "title": "Figure",
      "description": "A figure spawned in the game",
      "type": "object",
      "properties": {
        "assetId": {
          "type": "string"
        },
        "assetUrl": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["normal", "powerup", "bomb", "dodge"]
        },
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "spawnedAt": {
          "type": "number"
        },
        "caughtBy": {
          "type": "string"
        },
        "caughtAt": {
          "type": "number"
        }
      },
      "required": ["assetId", "assetUrl", "type", "x", "y", "spawnedAt"]
    }
  },
  "firestore": {
    "/games/{gameId}": {
      "schema": {
        "$ref": "#/entities/Game"
      },
      "description": "Game sessions"
    },
    "/games/{gameId}/players/{playerId}": {
      "schema": {
        "$ref": "#/entities/Player"
      },
      "description": "Players in a game session"
    },
    "/games/{gameId}/figures/{figureId}": {
      "schema": {
        "$ref": "#/entities/Figure"
      },
      "description": "Figures spawned in a game session"
    }
  }
}
